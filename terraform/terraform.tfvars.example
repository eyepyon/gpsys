# terraform.tfvars サンプルファイル
#
# 【重要】このファイルはサンプルであり、実際の認証情報（DBパスワード・
# Places APIキー等）は含めていない。実際に`terraform apply`を行う際は、
# このファイルを`terraform.tfvars`としてコピーした上で、機密値については
# 以下のいずれかの方法で値を渡すこと（ファイルへの平文記載は避けること）:
#   - 環境変数 `TF_VAR_db_password` / `TF_VAR_places_api_key` を設定する
#   - CI/CDのシークレットストア（例: GitHub Actions Secrets）から
#     `-var` オプションで渡す
#   - 既にSecret Manager上に値が存在する場合は、Terraformでの新規発行を
#     やめてデータソース（`data "google_secret_manager_secret_version"`）
#     による参照に切り替える
#
# `terraform.tfvars`（このファイルではなく実際の値を入れたファイル）は
# 必ず`.gitignore`に追加し、リポジトリにコミットしないこと。

project_id  = "your-gcp-project-id"
region      = "us-central1"
environment = "dev"

app_service_name = "regional-revitalization-api"
app_image        = "us-central1-docker.pkg.dev/your-gcp-project-id/regional-revitalization/api:latest"

inference_service_name = "regional-revitalization-infer"
inference_image        = "us-central1-docker.pkg.dev/your-gcp-project-id/regional-revitalization/infer:latest"

vacant_sync_job_name = "vacant-property-sync"
vacant_sync_image    = "us-central1-docker.pkg.dev/your-gcp-project-id/regional-revitalization/vacant-sync:latest"

vpc_network_name   = "default"
vpc_connector_cidr = "10.8.0.0/28"

db_instance_name = "regional-revitalization-db"
db_tier          = "db-custom-2-8192"
db_name          = "regional_revitalization"
db_user          = "app_user"
# db_password はサンプルに含めない。TF_VAR_db_password 環境変数等で渡すこと。

storage_bucket_name = "your-gcp-project-id-regional-revitalization-resources"

# places_api_key はサンプルに含めない。TF_VAR_places_api_key 環境変数等で渡すこと。

vacant_sync_schedule  = "0 3 * * *"
vacant_sync_time_zone = "Etc/UTC"

labels = {
  app = "regional-revitalization"
}

artifact_registry_repository_id = "regional-revitalization"

# GitHub ActionsからのCI/CDデプロイを有効化する場合はtrueにし、
# github_repository に "org-name/repo-name" 形式でリポジトリ名を指定する。
# 【注記】初回はfalseのまま人間の管理者権限で terraform apply し、
# デプロイ用サービスアカウント等を作成した後にtrueへ切り替えること。
enable_github_actions_wif = false
github_repository         = "your-org/your-repo"
